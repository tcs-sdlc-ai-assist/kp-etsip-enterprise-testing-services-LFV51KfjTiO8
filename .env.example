# Environment Variables Template
# Copy this file to .env and fill in the values

# Application title displayed in the browser tab and header
VITE_APP_TITLE=KP-ETSIP

# Default user role for development (e.g., admin, viewer, editor)
VITE_DEFAULT_ROLE=viewer

# Simulated network delay in milliseconds for mock API calls (0 to disable)
VITE_MOCK_DELAY_MS=300